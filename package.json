{
  "name": "docksy",
  "version": "1.0.0",
  "description": "Windows Workspace Restorer",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:frontend": "vite",
    "build:frontend": "tsc -p tsconfig.json && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dev": "concurrently \"npm run dev:frontend\" \"tsc -p tsconfig.electron.json -w\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "npm run build:frontend && npm run build:electron"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^8.2.2",
    "electron": "^31.1.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "wait-on": "^7.2.0"
  }
}
